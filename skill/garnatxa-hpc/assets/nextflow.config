// Nextflow config for the Garnatxa SLURM executor.
// Pair with a launcher .sbatch script (see nextflow_launcher.sbatch).

executor {
    queueSize = 200          // max concurrent child jobs
}

process {
    executor      = 'slurm'
    queue         = 'global' // SLURM partition (NOT the QoS)
    maxRetries    = 5
    errorStrategy = 'retry'
}

process {
    // Small, fast steps (e.g. indexing, sorting, light QC)
    withLabel: SHORT_PROCESS {
        memory         = { 1.GB * task.attempt }
        time           = { 5.minute * task.attempt }
        cpus           = 2
        clusterOptions = '--qos=short'
    }

    // Day-scale steps (e.g. alignment, variant calling)
    withLabel: GENERIC_PROCESS {
        memory         = { 5.GB * task.attempt }
        time           = { 1.day * task.attempt }
        cpus           = 8
        clusterOptions = '--qos=medium'
        errorStrategy  = { task.exitStatus >= 1 ? 'retry' : 'terminate' }
    }

    // Heavy long jobs (e.g. de novo assembly)
    withLabel: HEAVY_PROCESS {
        memory         = { 32.GB * task.attempt }
        time           = { 5.day * task.attempt }
        cpus           = 16
        clusterOptions = '--qos=long'
    }
}
